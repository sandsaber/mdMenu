{
  "name": "obmenu",
  "version": "0.1.0",
  "description": "A modern Markdown formatting toolbar for Obsidian.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build:dist": "tsc -noEmit -skipLibCheck && node scripts/build-dist.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "markdown",
    "toolbar"
  ],
  "author": "Michael Makarov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandsaber/obMenu.git"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "builtin-modules": "^4.0.0",
    "esbuild": "0.25.5",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
